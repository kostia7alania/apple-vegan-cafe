---
// Русский лендинг под кластер «веган доставка паттайя» (RU-выдача пуста —
// см. план §3). Копия вычитана разработчиком (носитель RU).
// hreflang: взаимная связка с EN /vegan-delivery-pattaya/ (см. alternates).
//
// Ссылки на заказ живут в CMS (settings.orderingLinks): пока провайдера
// «grab» нет — честная подсказка «найдите нас в приложении», при появлении
// ссылки страница сама апгрейдится до прямой кнопки GrabFood.
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import JayBadge from '../../components/JayBadge.astro';
import LeafDivider from '../../components/LeafDivider.astro';
import Sprig from '../../components/Sprig.astro';
import type { Locale } from '../../lib/i18n';
import { absoluteUrl, localePath } from '../../lib/urls';
import { buildBreadcrumb } from '../../lib/jsonld';
import { t, type UiKey } from '../../lib/ui';

const locale: Locale = 'ru';
const PAGE_PATH = '/ru/veganskaya-dostavka-v-pattaye/';

const [settings] = (await getCollection('settings')).map((e) => e.data);
const [location] = (await getCollection('locations')).map((e) => e.data);
if (!settings || !location) throw new Error('settings/locations content is missing');

// Те же блюда, что на EN-версии: хорошо переносят дорогу.
const DELIVERY_DISH_IDS = [
  'vegan-pad-thai',
  'pad-see-ew-vegan',
  'red-curry-vegan',
  'vegan-hamburger',
  'vegan-som-tum-thai',
];
const deliveryDishes = (
  await getCollection('dishes', ({ id, data }) => data.available && DELIVERY_DISH_IDS.includes(id))
)
  .sort((a, b) => DELIVERY_DISH_IDS.indexOf(a.id) - DELIVERY_DISH_IDS.indexOf(b.id))
  .map((e) => e.data);

const grabLink = settings.orderingLinks.find((l) => l.provider.toLowerCase().includes('grab'));

const alternates = { en: '/vegan-delivery-pattaya/', ru: PAGE_PATH };
const site = Astro.site!;

const title = 'Веганская доставка в Паттайе | Apple Vegan Cafe';
const description =
  '100% веганская тайская еда с доставкой по Паттайе через GrabFood или самовывозом. Семейная кухня — без яиц, молока и рыбного соуса.';

const jsonld = [
  buildBreadcrumb([
    { name: t(locale, 'nav.home'), url: absoluteUrl(site, localePath(locale, '/')) },
    { name: 'Доставка веганской еды в Паттайе', url: absoluteUrl(site, PAGE_PATH) },
  ]),
];

const menuPath = localePath(locale, '/menu/');
const phoneHref = `tel:${settings.phone.replace(/\s/g, '')}`;

const dayLabel = (d: string) => t(locale, `days.${d}` as UiKey);
const daysLabel = (days: readonly string[]) =>
  days.length === 7
    ? t(locale, 'days.daily')
    : days.length > 2
      ? `${dayLabel(days[0]!)}–${dayLabel(days.at(-1)!)}`
      : days.map(dayLabel).join(', ');
---

<Base {locale} {title} {description} {alternates} {jsonld}>
  <section
    class="relative overflow-hidden bg-leaf-900 bg-[radial-gradient(60rem_30rem_at_85%_-10%,rgba(232,161,60,0.16),transparent_60%)] text-cream-100"
  >
    <Sprig
      class="pointer-events-none absolute top-4 -right-6 h-64 w-auto rotate-12 text-cream-100/10 sm:-top-4 sm:right-2 sm:h-80"
    />
    <Sprig
      class="pointer-events-none absolute -bottom-14 -left-10 h-52 w-auto -rotate-[30deg] text-mango-500/10"
    />
    <div class="wrap relative py-14 sm:py-20">
      <p class="rise">
        <JayBadge label={t(locale, 'trust.jay')} />
      </p>
      <h1
        class="rise rise-1 mt-5 max-w-[24ch] font-display text-4xl leading-[1.15] font-extrabold tracking-tight text-balance text-cream-50 sm:text-5xl"
      >
        Веганская доставка в Паттайе
      </h1>
      <p class="rise rise-2 mt-4 max-w-[52ch] text-lg text-leaf-200 sm:text-xl">
        Наша маленькая семейная кухня — у вашей двери. Или собранный заказ ждёт вас у стойки
      </p>
      <p
        class="rise rise-2 mt-6 inline-flex items-center gap-2.5 rounded-full border border-cream-100/25 px-4 py-2 text-sm font-medium"
      >
        <span class="h-2 w-2 rounded-full bg-mango-400" aria-hidden="true"></span>
        Самовывоз ежедневно 7:00–22:00 · Grab — часто круглосуточно
      </p>
      <div class="rise rise-3 mt-8 flex flex-wrap gap-3">
        <a
          href={menuPath}
          class="inline-flex min-h-12 items-center rounded-full bg-mango-500 px-7 text-base font-bold text-ink-900 transition-colors hover:bg-mango-300 focus-visible:outline-mango-300"
        >
          {t(locale, 'home.viewMenu')}
        </a>
        <a
          href={phoneHref}
          class="inline-flex min-h-12 items-center rounded-full border border-cream-100/40 px-7 text-base font-semibold text-cream-100 transition-colors hover:border-cream-100 hover:bg-leaf-800 focus-visible:outline-mango-300"
        >
          {`${t(locale, 'actions.call')} ${settings.phone}`}
        </a>
      </div>
    </div>
  </section>

  <section class="wrap py-12 sm:py-14">
    <div class="prose-editorial">
      <p>
        Бывают вечера, когда выходить из номера не хочется совсем — мы понимаем. Мы —{' '}
        <strong>Apple Vegan Cafe &amp; Restaurant</strong>, семейное кафе в Банг Ламунге, и всё, что
        мы готовим, — 100% растительное. На нашей кухне{' '}
        <strong>нет мяса, рыбного соуса, яиц и молочных продуктов</strong> — вообще. Еда одна и та же
        честная — что на нашем столике, что в пакете у курьера.
      </p>
      <p>
        А наутро приходите сами: у нас{' '}
        <a href="/ru/veganskiy-zavtrak-v-pattaye/"
          >один из самых ранних веганских завтраков в Паттайе</a
        >{' '}
        — с 7:00 каждый день. И если хотите разобраться в веганской Паттайе целиком, вот наш{' '}
        <a href="/ru/blog/vegan-gid-po-pattaye/">короткий честный гид</a>.
      </p>
    </div>
    <LeafDivider class="mt-10 max-w-60" />
  </section>

  <section class="wrap pb-12">
    <h2 class="font-display text-3xl font-bold tracking-tight text-leaf-900 sm:text-4xl">
      Как заказать
    </h2>
    {
      grabLink ? (
        <>
          <p class="mt-3 max-w-[60ch] leading-relaxed text-ink-700">
            Мы есть в <strong>GrabFood</strong> — нажмите кнопку ниже, соберите заказ, и курьер
            привезёт его ещё тёплым.
          </p>
          <p class="mt-5">
            <a
              href={grabLink.url}
              rel="noopener"
              class="inline-flex min-h-12 items-center rounded-full bg-leaf-700 px-7 font-bold text-cream-50 transition-colors hover:bg-leaf-800"
            >
              Заказать в GrabFood
            </a>
          </p>
        </>
      ) : (
        <p class="mt-3 max-w-[60ch] leading-relaxed text-ink-700">
          Доставка работает через <strong>Grab</strong> — откройте приложение GrabFood и найдите{' '}
          <strong>«Apple Vegan Cafe»</strong>. Там всё наше меню, курьер привезёт заказ ещё тёплым.
        </p>
      )
    }
    <p class="mt-4 max-w-[60ch] leading-relaxed text-ink-700">
      Не хочется через приложение? Позвоните, скажите, что собрать, — и заберите у стойки: заказ
      будет упакован и готов к вашему приходу.
    </p>
    <p class="mt-5">
      <a
        href={phoneHref}
        class="inline-flex min-h-12 items-center rounded-full border border-leaf-700/40 px-6 font-semibold text-leaf-800 transition-colors hover:border-leaf-700 hover:bg-leaf-100"
      >
        {`${t(locale, 'actions.call')} ${settings.phone} — самовывоз`}
      </a>
    </p>

    <div
      class="mt-8 max-w-[62ch] rounded-3xl border border-leaf-700/15 bg-leaf-50 px-6 py-6 sm:px-8"
    >
      <h3 class="font-display text-xl font-bold text-leaf-900">
        🌙 Захотелось пад тая в два часа ночи? Всё равно проверьте приложение
      </h3>
      <p class="mt-2 leading-relaxed text-ink-700">
        Зал работает с 7:00 до 22:00, но мы семейный бизнес и заказы в Grab часто{' '}
        <strong>принимаем почти круглосуточно</strong> — ночной заказ буквально будит кухню. Актуальный
        статус всегда виден в приложении Grab: если написано «открыто» — мы уже готовим.
      </p>
    </div>
  </section>

  <section class="wrap pb-12">
    <div
      class="relative overflow-hidden rounded-3xl border border-jay-500/20 bg-mango-200/30 px-6 py-8 sm:px-10 sm:py-10"
    >
      <Sprig
        class="pointer-events-none absolute -right-6 -bottom-9 h-44 w-auto text-jay-500 opacity-10"
      />
      <h2 class="font-display text-2xl font-bold tracking-tight text-leaf-900 sm:text-3xl">
        Честно про цены
      </h2>
      <p class="relative mt-3 max-w-[62ch] leading-relaxed text-ink-700">
        В приложениях доставки блюда обычно стоят чуть дороже, чем за нашими столиками, — так
        устроены сами приложения. Меню на этом сайте совпадает с нашим{' '}
        <strong>меню в GrabFood</strong>, а <strong
          >у стойки самовывоз часто немного дешевле — просто спросите нас</strong
        >. Так что если вы рядом, забрать заказ самому — самый выгодный вариант. И повод
        поздороваться.
      </p>
    </div>
  </section>

  <section class="wrap pb-12">
    <div class="flex items-baseline justify-between gap-4">
      <h2 class="font-display text-3xl font-bold tracking-tight text-leaf-900 sm:text-4xl">
        Что хорошо едет в доставке
      </h2>
      <a
        href={menuPath}
        class="hidden text-sm font-semibold text-leaf-700 underline decoration-mango-500 decoration-2 underline-offset-4 transition-colors hover:text-leaf-900 sm:inline"
      >
        {t(locale, 'home.viewMenu')} →
      </a>
    </div>
    <p class="mt-3 max-w-[60ch] text-ink-500">
      Несколько блюд, которые особенно хорошо переносят дорогу: карри и лапша доезжают такими же,
      какими вышли из кухни. Цены совпадают с нашим меню в GrabFood.
    </p>
    <ul class="mt-4 divide-y divide-cream-200">
      {
        deliveryDishes.map((dish) => (
          <li class="py-5">
            <div class="flex items-baseline gap-3">
              <h3 class="font-display text-lg leading-snug font-bold">
                <a
                  href={`${menuPath}#${dish.slug[locale]}`}
                  class="transition-colors hover:text-leaf-800"
                >
                  {dish.name[locale]}
                </a>
              </h3>
              <span class="leader" aria-hidden="true" />
              <span class="text-lg font-bold whitespace-nowrap text-leaf-800 tabular-nums">
                ฿{dish.price_thb}
              </span>
            </div>
            {dish.description?.[locale] && (
              <p class="mt-1.5 max-w-[56ch] text-sm leading-relaxed text-ink-500">
                {dish.description[locale]}
              </p>
            )}
          </li>
        ))
      }
    </ul>
    <p class="mt-6">
      <a
        href={menuPath}
        class="inline-flex min-h-12 items-center rounded-full bg-leaf-700 px-7 font-bold text-cream-50 transition-colors hover:bg-leaf-800"
      >
        Полное меню с ценами
      </a>
    </p>
  </section>

  <section class="wrap pb-12">
    <div
      class="relative overflow-hidden rounded-3xl border border-leaf-100 bg-leaf-50 px-6 py-8 sm:px-10 sm:py-10"
    >
      <Sprig
        class="pointer-events-none absolute -right-6 -bottom-9 h-44 w-auto text-leaf-700 opacity-[0.13]"
      />
      <h2 class="font-display text-2xl font-bold tracking-tight text-leaf-900 sm:text-3xl">
        {t(locale, 'home.findUs')}
      </h2>
      <p class="relative mt-3 max-w-[62ch] leading-relaxed text-ink-700">
        Кухня готовит <strong>с 7:00 до 22:00, каждый день</strong> — и ранние завтраки с собой, и поздние
        ужины.
      </p>
      <div class="relative mt-6 grid gap-8 sm:grid-cols-2">
        <div>
          <h3 class="text-xs font-bold tracking-[0.14em] text-terracotta-700 uppercase">
            {t(locale, 'contact.address')}
          </h3>
          <p class="mt-2 max-w-[36ch] leading-relaxed">{location.address[locale]}</p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a
              href={phoneHref}
              class="inline-flex min-h-12 items-center gap-2.5 rounded-full bg-leaf-700 px-6 font-bold text-cream-50 transition-colors hover:bg-leaf-800"
            >
              <svg
                viewBox="0 0 24 24"
                class="h-4.5 w-4.5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                ></path>
              </svg>
              {settings.phone}
            </a>
            <a
              href={menuPath}
              class="inline-flex min-h-12 items-center rounded-full border border-leaf-700/40 px-6 font-semibold text-leaf-800 transition-colors hover:border-leaf-700 hover:bg-leaf-100"
            >
              Смотреть меню
            </a>
          </div>
        </div>
        <div>
          <h3 class="text-xs font-bold tracking-[0.14em] text-terracotta-700 uppercase">
            {t(locale, 'contact.hours')}
          </h3>
          <table class="mt-2 text-left">
            <tbody>
              {
                location.hours.map((h) => (
                  <tr>
                    <th scope="row" class="py-1 pr-6 font-medium">
                      {daysLabel(h.days)}
                    </th>
                    <td class="py-1 tabular-nums">
                      <strong>{h.open}</strong>–{h.close}
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</Base>
