---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import JayBadge from '../../components/JayBadge.astro';
import Sprig from '../../components/Sprig.astro';
import { localeStaticPaths, type Locale } from '../../lib/i18n';
import { absoluteUrl, localePath, structuralAlternates } from '../../lib/urls';
import { buildRestaurant } from '../../lib/jsonld';
import { t, type UiKey } from '../../lib/ui';

export function getStaticPaths() {
  return localeStaticPaths();
}

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const [settings] = (await getCollection('settings')).map((e) => e.data);
const [location] = (await getCollection('locations')).map((e) => e.data);
if (!settings || !location) throw new Error('settings/locations content is missing');

const availableDishes = await getCollection('dishes', ({ data }) => data.available);
const featured = availableDishes.filter((e) => e.data.featured).map((e) => e.data);
const categories = await getCollection('categories');
const categoryName = (id: string) => categories.find((c) => c.id === id)?.data.name[locale];
const grabLink = settings.orderingLinks.find((l) => l.provider.toLowerCase().includes('grab'));

const alternates = structuralAlternates('/');
const site = Astro.site!;

const jsonld = [
  buildRestaurant({
    name: settings.name,
    url: absoluteUrl(site, '/'),
    menuUrl: absoluteUrl(site, localePath(locale, '/menu/')),
    telephone: settings.phone,
    address: location.address.en,
    geo: location.geo,
    images: [],
    sameAs: [
      ...settings.social.map((s) => s.url),
      ...(settings.reviewLinks.happycow ? [settings.reviewLinks.happycow] : []),
    ],
    hours: location.hours,
    orderUrl: settings.orderingLinks.find((l) => l.provider.toLowerCase().includes('grab'))?.url,
  }),
];

const title = {
  en: 'Vegan Restaurant & Cafe in Pattaya | Apple Vegan Cafe',
  th: 'ร้านอาหารเจ พัทยา | Apple Vegan Cafe',
  ru: 'Веганское кафе в Паттайе | Apple Vegan Cafe',
}[locale];
const description = {
  en: '100% vegan restaurant and cafe in Pattaya serving Thai food, smoothies and coffee daily from 7:00. Family-run, plant-based only — no fish sauce, no egg, no dairy.',
  th: 'ร้านอาหารเจ 100% ในพัทยา มีอาหารไทย สมูทตี้ กาแฟ เปิดทุกวันตั้งแต่ 7:00 น. ไม่มีน้ำปลา ไข่ หรือนม',
  ru: '100% веганское кафе в Паттайе: тайская еда, смузи и кофе каждый день с 7:00. Без рыбного соуса, яиц и молочных продуктов.',
}[locale];
const heroTitle = {
  en: 'Vegan Restaurant & Cafe in Pattaya',
  th: 'ร้านอาหารเจ พัทยา',
  ru: 'Веганское кафе в Паттайе',
}[locale];
const heroIntro = {
  en: 'Apple Vegan Cafe is a family-run 100% plant-based Thai kitchen with 141 dishes, GrabFood delivery and breakfast from 7:00.',
  th: 'Apple Vegan Cafe เป็นร้านอาหารเจ 100% ของครอบครัว มี 141 เมนู สั่งผ่าน GrabFood ได้ และเปิดตั้งแต่ 7:00 น.',
  ru: 'Apple Vegan Cafe — семейная 100% растительная тайская кухня: 141 блюдо, доставка GrabFood и завтраки с 7:00.',
}[locale];

const menuPath = localePath(locale, '/menu/');
const phoneHref = `tel:${settings.phone.replace(/\s/g, '')}`;

const dayLabel = (d: string) => t(locale, `days.${d}` as UiKey);
const daysLabel = (days: readonly string[]) =>
  days.length === 7
    ? t(locale, 'days.daily')
    : days.length > 2
      ? `${dayLabel(days[0]!)}–${dayLabel(days.at(-1)!)}`
      : days.map(dayLabel).join(', ');

const [mainHours] = location.hours;
const dayRange = mainHours ? daysLabel(mainHours.days) : '';
const openChip = mainHours
  ? t(locale, 'home.openChip')
      .replace('{days}', dayRange)
      .replace('{open}', mainHours.open.replace(/^0/, ''))
  : '';
---

<Base {locale} {title} {description} {alternates} {jsonld}>
  <section
    class="relative min-h-[78svh] overflow-hidden bg-leaf-900 text-cream-100 sm:min-h-[72svh]"
  >
    <picture>
      <source
        type="image/avif"
        srcset="/hero-vegan-table-960.avif 960w, /hero-vegan-table-1600.avif 1600w"
        sizes="100vw"
      />
      <source
        type="image/webp"
        srcset="/hero-vegan-table-960.webp 960w, /hero-vegan-table-1600.webp 1600w"
        sizes="100vw"
      />
      <img
        src="/hero-vegan-table.webp"
        alt=""
        width="1600"
        height="900"
        fetchpriority="high"
        class="absolute inset-0 h-full w-full object-cover"
      />
    </picture>
    <div
      class="absolute inset-0 bg-linear-to-r from-leaf-900/95 via-leaf-900/70 to-leaf-900/10"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute inset-0 bg-linear-to-t from-leaf-900/70 via-transparent to-transparent"
      aria-hidden="true"
    >
    </div>
    <div
      class="wrap relative flex min-h-[78svh] flex-col justify-end py-12 sm:min-h-[72svh] sm:py-16"
    >
      <p class="rise">
        <JayBadge label={t(locale, 'trust.jay')} />
      </p>
      <h1
        class="rise rise-1 mt-5 max-w-[16ch] text-4xl leading-[1.02] font-black tracking-tight text-balance text-cream-50 sm:text-7xl"
      >
        {heroTitle}
      </h1>
      <p class="rise rise-2 mt-5 max-w-[44ch] text-lg leading-relaxed text-cream-100/88 sm:text-xl">
        {heroIntro}
      </p>
      {
        openChip && (
          <p class="rise rise-2 mt-6 inline-flex w-fit items-center gap-2.5 rounded-lg border border-cream-100/25 bg-cream-50/10 px-4 py-2 text-sm font-semibold backdrop-blur-md">
            <svg
              viewBox="0 0 24 24"
              class="h-4 w-4 shrink-0 text-mango-300"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="9" />
              <path d="M12 7v5l3 2" />
            </svg>
            {openChip}
          </p>
        )
      }
      <div class="rise rise-3 mt-8 flex flex-wrap gap-3">
        {
          grabLink && (
            <a
              href={grabLink.url}
              rel="noopener"
              class="inline-flex min-h-12 items-center rounded-lg bg-mango-500 px-7 text-base font-extrabold text-ink-900 transition-colors hover:bg-mango-300 focus-visible:outline-mango-300"
            >
              {t(locale, 'home.orderGrab')}
            </a>
          )
        }
        <a
          href={menuPath}
          class:list={[
            'inline-flex min-h-12 items-center rounded-lg px-7 text-base font-semibold transition-colors focus-visible:outline-mango-300',
            grabLink
              ? 'border border-cream-100/45 bg-cream-50/10 text-cream-100 backdrop-blur-md hover:border-cream-100 hover:bg-cream-50/18'
              : 'bg-mango-500 text-ink-900 hover:bg-mango-300',
          ]}
        >
          {t(locale, 'home.viewMenu')}
        </a>
        {
          location.mapsUrl && (
            <a
              href={location.mapsUrl}
              rel="noopener"
              class="inline-flex min-h-12 items-center rounded-lg border border-cream-100/45 bg-cream-50/10 px-7 text-base font-semibold text-cream-100 backdrop-blur-md transition-colors hover:border-cream-100 hover:bg-cream-50/18 focus-visible:outline-mango-300"
            >
              {t(locale, 'home.getDirections')}
            </a>
          )
        }
      </div>
    </div>
  </section>

  <section class="border-b border-cream-300/80 bg-cream-50">
    <ul class="wrap grid grid-cols-2 gap-3 py-5 text-sm text-ink-700 sm:grid-cols-4">
      <li class="rounded-lg border border-cream-300 bg-cream-100 px-4 py-3">
        <p>
          <JayBadge label={t(locale, 'trust.jay')} size="sm" />
        </p>
        <p class="mt-2 text-xs font-semibold text-ink-500">{t(locale, 'trust.honest')}</p>
      </li>
      <li class="rounded-lg border border-cream-300 bg-cream-100 px-4 py-3">
        <p class="text-lg font-black text-leaf-900 tabular-nums">
          {t(locale, 'home.menuCount').replace('{count}', String(availableDishes.length))}
        </p>
        <p class="mt-1 text-xs font-semibold text-ink-500">{t(locale, 'home.menuCountNote')}</p>
      </li>
      <li class="rounded-lg border border-cream-300 bg-cream-100 px-4 py-3">
        <p class="flex items-center gap-2 font-black text-leaf-900">
          <svg
            viewBox="0 0 24 24"
            class="h-4.5 w-4.5 shrink-0 text-mango-500"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M12 7v5l3 2"></path>
          </svg>
          {t(locale, 'home.openDailyNote')}
        </p>
        <p class="mt-1 text-xs font-semibold text-ink-500">{t(locale, 'trust.family')}</p>
      </li>
      <li class="rounded-lg border border-cream-300 bg-cream-100 px-4 py-3">
        <a href={settings.reviewLinks.happycow} rel="noopener" class="group block">
          <span class="flex items-center gap-2 font-black text-leaf-900">
            <svg viewBox="0 0 24 24" class="h-4.5 w-4.5 shrink-0 fill-mango-500" aria-hidden="true">
              <path
                d="M12 2l2.9 6.26 6.6 1.01-4.75 4.63L17.9 20.5 12 17.27 6.1 20.5l1.15-6.6L2.5 9.27l6.6-1.01z"
              ></path>
            </svg>
            {t(locale, 'trust.happycow')}
          </span>
          <span class="mt-1 block text-xs font-semibold text-ink-500 group-hover:text-leaf-800">
            {t(locale, 'home.happyCowNote')}
          </span>
        </a>
      </li>
    </ul>
  </section>

  <section class="wrap pt-10">
    <div class="grid gap-3 sm:grid-cols-3">
      <a
        href={menuPath}
        class="flex min-h-20 items-center gap-4 rounded-lg border border-cream-300 bg-cream-50 px-4 py-3 transition-colors hover:border-leaf-700/35 hover:bg-leaf-50"
      >
        <svg
          viewBox="0 0 24 24"
          class="h-5 w-5 shrink-0 text-leaf-700"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="5" y="3.5" width="14" height="17" rx="2"></rect>
          <path d="M9 8h6M9 12h6M9 16h4"></path>
        </svg>
        <span>
          <span class="block font-extrabold text-leaf-900">{t(locale, 'home.viewMenu')}</span>
          <span class="mt-0.5 block text-sm text-ink-500">
            {t(locale, 'home.menuCount').replace('{count}', String(availableDishes.length))}
          </span>
        </span>
      </a>
      {
        grabLink && (
          <a
            href={grabLink.url}
            rel="noopener"
            class="flex min-h-20 items-center gap-4 rounded-lg border border-mango-300 bg-mango-500 px-4 py-3 text-ink-900 transition-colors hover:bg-mango-300"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-5 w-5 shrink-0"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
              <path d="M3 6h18" />
              <path d="M16 10a4 4 0 0 1-8 0" />
            </svg>
            <span>
              <span class="block font-extrabold">{t(locale, 'home.orderGrab')}</span>
              <span class="mt-0.5 block text-sm text-ink-700">
                {t(locale, 'hours.deliveryValue')}
              </span>
            </span>
          </a>
        )
      }
      <a
        href={phoneHref}
        class="flex min-h-20 items-center gap-4 rounded-lg border border-cream-300 bg-cream-50 px-4 py-3 transition-colors hover:border-leaf-700/35 hover:bg-leaf-50"
      >
        <svg
          viewBox="0 0 24 24"
          class="h-5 w-5 shrink-0 text-leaf-700"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
          ></path>
        </svg>
        <span>
          <span class="block font-extrabold text-leaf-900">{t(locale, 'actions.call')}</span>
          <span class="mt-0.5 block text-sm text-ink-500">{settings.phone}</span>
        </span>
      </a>
    </div>
  </section>

  {
    /* EN-only: internal link to the vegan-breakfast landing page (backlog R2).
       Locale-conditional — the TH/RU home pages must not render this block. */
    locale === 'en' && (
      <section class="wrap pt-10">
        <a
          href="/vegan-breakfast-pattaya/"
          class="group flex flex-wrap items-center justify-between gap-x-6 gap-y-3 rounded-lg border border-jay-500/25 bg-mango-200/35 px-6 py-5 transition-colors hover:border-jay-500/45 hover:bg-mango-200/55"
        >
          <span class="flex min-w-0 items-center gap-3">
            <span
              class="font-display text-2xl leading-none font-bold whitespace-nowrap text-jay-700"
              aria-hidden="true"
            >
              7:00
            </span>
            <span class="font-semibold text-ink-900">
              Early riser? We serve one of the earliest vegan breakfasts in Pattaya — doors open
              7:00, every day
            </span>
          </span>
          <span class="text-sm font-bold whitespace-nowrap text-jay-700 underline decoration-jay-500/50 decoration-2 underline-offset-4 group-hover:text-jay-500">
            Read more →
          </span>
        </a>
      </section>
    )
  }

  {
    /* RU-only: contextual links to the Russian breakfast and delivery landing pages. */
    locale === 'ru' && (
      <section class="wrap pt-10">
        <div class="grid gap-3 sm:grid-cols-2">
          <a
            href="/ru/veganskiy-zavtrak-v-pattaye/"
            class="group flex min-h-20 items-center justify-between gap-x-5 gap-y-3 rounded-lg border border-jay-500/25 bg-mango-200/35 px-6 py-5 transition-colors hover:border-jay-500/45 hover:bg-mango-200/55"
          >
            <span class="flex min-w-0 items-center gap-3">
              <span
                class="font-display text-2xl leading-none font-bold whitespace-nowrap text-jay-700"
                aria-hidden="true"
              >
                7:00
              </span>
              <span class="font-semibold text-ink-900">
                Рано встали? Веганский завтрак в Паттайе каждый день с 7:00
              </span>
            </span>
            <span class="text-sm font-bold whitespace-nowrap text-jay-700 underline decoration-jay-500/50 decoration-2 underline-offset-4 group-hover:text-jay-500">
              Читать →
            </span>
          </a>
          <a
            href="/ru/veganskaya-dostavka-v-pattaye/"
            class="group flex min-h-20 items-center justify-between gap-x-5 gap-y-3 rounded-lg border border-leaf-700/20 bg-leaf-50 px-6 py-5 transition-colors hover:border-leaf-700/40 hover:bg-leaf-100"
          >
            <span class="flex min-w-0 items-center gap-3">
              <span
                class="font-display text-2xl leading-none font-bold whitespace-nowrap text-leaf-700"
                aria-hidden="true"
              >
                Grab
              </span>
              <span class="font-semibold text-ink-900">
                Доставка через GrabFood и самовывоз, если не хочется выходить
              </span>
            </span>
            <span class="text-sm font-bold whitespace-nowrap text-leaf-700 underline decoration-leaf-500/50 decoration-2 underline-offset-4 group-hover:text-leaf-900">
              Читать →
            </span>
          </a>
        </div>
      </section>
    )
  }

  {
    /* TH-only: internal link to the seasonal เจ landing page (backlog R1).
       Locale-conditional — the EN/RU home pages must not render this block. */
    locale === 'th' && (
      <section class="wrap pt-10">
        <a
          href="/th/ร้านอาหารเจ-พัทยา/"
          class="group flex flex-wrap items-center justify-between gap-x-6 gap-y-3 rounded-lg border border-jay-500/25 bg-mango-200/35 px-6 py-5 transition-colors hover:border-jay-500/45 hover:bg-mango-200/55"
        >
          <span class="flex min-w-0 items-center gap-3">
            <span
              class="font-display text-2xl leading-none font-bold text-jay-700"
              aria-hidden="true"
            >
              เจ
            </span>
            <span class="font-semibold text-ink-900">
              มองหาร้านอาหารเจในพัทยา? ครัวเราเป็นเจ 100% ทุกวันตลอดปี — ไม่ใช่เฉพาะเทศกาลกินเจ
            </span>
          </span>
          <span class="text-sm font-bold whitespace-nowrap text-jay-700 underline decoration-jay-500/50 decoration-2 underline-offset-4 group-hover:text-jay-500">
            อ่านต่อ →
          </span>
        </a>
      </section>
    )
  }

  {
    featured.length > 0 && (
      <section class="wrap py-14 sm:py-16">
        <div class="flex items-baseline justify-between gap-4">
          <h2 class="section-heading text-3xl font-black tracking-tight text-leaf-900 sm:text-4xl">
            {t(locale, 'home.featured')}
          </h2>
          <a
            href={menuPath}
            class="hidden text-sm font-semibold text-leaf-700 underline decoration-mango-500 decoration-2 underline-offset-4 transition-colors hover:text-leaf-900 sm:inline"
          >
            {t(locale, 'home.viewMenu')} →
          </a>
        </div>
        <ul class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {featured.map((dish) => (
            <li>
              <article class="group relative flex h-full flex-col rounded-lg border border-cream-300 bg-cream-50 p-5 transition-[border-color,box-shadow] hover:border-leaf-600/50 hover:shadow-[0_14px_34px_-20px_rgba(38,34,27,0.32)]">
                {dish.images[0] && (
                  <img
                    src={dish.images[0]}
                    alt={dish.name[locale]}
                    loading="lazy"
                    width="640"
                    height="480"
                    class="mb-4 aspect-4/3 w-full rounded-md border border-cream-300 object-cover"
                  />
                )}
                <p class="text-[11px] font-bold text-terracotta-700 uppercase">
                  {categoryName(dish.category.id)}
                </p>
                <h3 class="mt-2 text-xl leading-snug font-extrabold">
                  <a
                    href={`${menuPath}#${dish.slug[locale]}`}
                    class="transition-colors after:absolute after:inset-0 after:rounded-lg group-hover:text-leaf-800"
                  >
                    {dish.name[locale]}
                  </a>
                </h3>
                {dish.description?.[locale] && (
                  <p class="mt-2 text-sm leading-relaxed text-ink-500">
                    {dish.description[locale]}
                  </p>
                )}
                <p class="mt-auto flex items-center justify-between pt-5">
                  <span class="rounded-md bg-leaf-700 px-3 py-1 text-sm font-bold text-cream-50 tabular-nums">
                    ฿{dish.price_thb}
                  </span>
                  <span
                    class="text-sm font-semibold text-leaf-700 opacity-0 transition-opacity group-hover:opacity-100"
                    aria-hidden="true"
                  >
                    {t(locale, 'home.seeInMenu')} →
                  </span>
                </p>
              </article>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="wrap pb-4">
    <div
      class="decor-card relative overflow-hidden rounded-lg border border-leaf-100 bg-leaf-50 px-6 py-8 sm:px-10 sm:py-10"
    >
      <Sprig
        class="pointer-events-none absolute -right-6 -bottom-9 h-44 w-auto text-leaf-700 opacity-[0.13]"
      />
      <h2
        class="section-heading relative text-2xl font-black tracking-tight text-leaf-900 sm:text-3xl"
      >
        {t(locale, 'home.findUs')}
      </h2>
      <div class="relative mt-6 grid gap-8 sm:grid-cols-2">
        <div>
          <h3 class="text-xs font-bold tracking-[0.14em] text-terracotta-700 uppercase">
            {t(locale, 'contact.address')}
          </h3>
          <p class="mt-2 max-w-[36ch] leading-relaxed">{location.address[locale]}</p>
          <a
            href={phoneHref}
            class="mt-5 inline-flex min-h-12 items-center gap-2.5 rounded-lg bg-leaf-700 px-6 font-bold text-cream-50 transition-colors hover:bg-leaf-800"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-4.5 w-4.5"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
            {settings.phone}
          </a>
        </div>
        <div>
          <h3 class="text-xs font-bold tracking-[0.14em] text-terracotta-700 uppercase">
            {t(locale, 'contact.hours')}
          </h3>
          <table class="mt-2 text-left">
            <tbody>
              {
                location.hours.map((h) => (
                  <tr>
                    <th scope="row" class="py-1 pr-6 font-medium">
                      {daysLabel(h.days)}
                    </th>
                    <td class="py-1 tabular-nums">
                      {h.open}–{h.close}
                    </td>
                  </tr>
                ))
              }
              <tr>
                <th scope="row" class="py-1 pr-6 font-medium">{t(locale, 'hours.delivery')}</th>
                <td class="py-1">{t(locale, 'hours.deliveryValue')}</td>
              </tr>
            </tbody>
          </table>
          <p class="mt-3 max-w-[40ch] text-sm leading-relaxed text-ink-500">
            {t(locale, 'contact.nightOrders')}
          </p>
          <p class="mt-4">
            <a
              href={localePath(locale, '/contact/')}
              class="font-semibold text-leaf-700 underline decoration-mango-500 decoration-2 underline-offset-4 transition-colors hover:text-leaf-900"
            >
              {t(locale, 'nav.contact')} →
            </a>
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>
