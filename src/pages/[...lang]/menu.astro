---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import JayBadge from '../../components/JayBadge.astro';
import { localeStaticPaths, type Locale } from '../../lib/i18n';
import { absoluteUrl, localePath, structuralAlternates } from '../../lib/urls';
import { buildBreadcrumb, buildMenu } from '../../lib/jsonld';
import { t, type UiKey } from '../../lib/ui';

export function getStaticPaths() {
  return localeStaticPaths();
}

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

// small visual anchors for cross-cultural guests (เจ has its own JayBadge)
const TAG_ICONS: Partial<Record<string, string>> = {
  vegan: '🌱',
  'jain-friendly': '🪷',
  'gluten-free': '🌾',
};

const [settings] = (await getCollection('settings')).map((e) => e.data);
// Ordering links live in the CMS; the buttons appear once a «grab» provider exists.
const grabLink = settings?.orderingLinks.find((l) => l.provider.toLowerCase().includes('grab'));

const categories = (await getCollection('categories')).sort((a, b) => a.data.order - b.data.order);
// The owner's "stop list": unavailable dishes disappear from the menu entirely.
const dishes = await getCollection('dishes', ({ data }) => data.available);
const allergens = await getCollection('allergens');
const allergenName = (id: string) => allergens.find((a) => a.id === id)?.data.name[locale] ?? id;

const nonEmptyCategories = categories.filter((category) =>
  dishes.some((d) => d.data.category.id === category.id),
);

const alternates = structuralAlternates('/menu/');
const site = Astro.site!;

const title = {
  en: 'Menu & prices — Apple Vegan Cafe Pattaya',
  th: 'เมนูและราคา — ร้านอาหารเจ คาเฟ่เจ พัทยา',
  ru: 'Меню и цены — Apple Vegan Cafe, Паттайя',
}[locale];
const description = {
  en: 'Full menu of Apple Vegan Cafe & Restaurant in Pattaya with prices in Thai Baht. 100% vegan Thai and Western dishes, updated by the family.',
  th: 'เมนูทั้งหมดของร้านอาหารเจ คาเฟ่เจ พัทยา พร้อมราคา อัปเดตโดยครอบครัว',
  ru: 'Полное меню Apple Vegan Cafe в Паттайе с ценами в батах. 100% веганские тайские и европейские блюда.',
}[locale];

const jsonld = [
  buildBreadcrumb([
    { name: t(locale, 'nav.home'), url: absoluteUrl(site, localePath(locale, '/')) },
    { name: t(locale, 'nav.menu'), url: absoluteUrl(site, localePath(locale, '/menu/')) },
  ]),
  buildMenu({
    url: absoluteUrl(site, localePath(locale, '/menu/')),
    locale,
    sections: nonEmptyCategories.map((category) => ({
      name: category.data.name[locale],
      items: dishes
        .filter((d) => d.data.category.id === category.id)
        .map(({ data: dish }) => ({
          name: dish.name[locale],
          price: dish.price_thb,
          description: dish.description?.[locale],
        })),
    })),
  }),
];
---

<Base {locale} {title} {description} {alternates} {jsonld}>
  <div id="top" class="wrap pt-10 pb-2 sm:pt-14">
    <JayBadge label={t(locale, 'trust.jay')} />
    <h1 class="mt-4 text-4xl font-black tracking-tight text-leaf-900 sm:text-5xl">
      {t(locale, 'menu.title')}
    </h1>
    <p class="mt-3 max-w-[52ch] text-ink-500">{t(locale, 'trust.honest')}</p>
    {
      grabLink && (
        <p class="mt-5">
          <a
            href={grabLink.url}
            rel="noopener"
            class="inline-flex min-h-12 items-center rounded-lg bg-mango-500 px-7 text-base font-extrabold text-ink-900 transition-colors hover:bg-mango-300 focus-visible:outline-mango-300"
          >
            {t(locale, 'menu.orderGrab')}
          </a>
        </p>
      )
    }
  </div>

  <nav
    aria-label={t(locale, 'menu.categoriesNav')}
    class="sticky top-0 z-30 border-b border-cream-300/80 bg-cream-100/95"
  >
    <div class="wrap">
      <ul class="scrollbar-none -mx-1 flex gap-2 overflow-x-auto px-1 py-3">
        {
          nonEmptyCategories.map((category) => (
            <li>
              <a
                href={`#${category.data.slug[locale]}`}
                class="inline-flex min-h-11 items-center gap-1.5 rounded-lg border border-leaf-700/20 bg-cream-50 px-4 text-sm font-semibold whitespace-nowrap text-leaf-800 transition-colors hover:border-leaf-700 hover:bg-leaf-100"
              >
                {category.data.name[locale]}
                <span class="text-xs font-normal text-ink-500 tabular-nums" aria-hidden="true">
                  {dishes.filter((d) => d.data.category.id === category.id).length}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>

  <div class="wrap pb-4">
    {
      nonEmptyCategories.map((category) => {
        const items = dishes.filter((d) => d.data.category.id === category.id);
        return (
          <section id={category.data.slug[locale]} class="scroll-mt-24 pt-12">
            <div class="flex items-center gap-4">
              <h2 class="text-2xl font-black tracking-tight text-leaf-900 sm:text-3xl">
                {category.data.name[locale]}
              </h2>
              <span class="h-px flex-1 bg-cream-300" aria-hidden="true" />
            </div>
            <ul class="mt-4 grid gap-2">
              {items.map(({ data: dish }) => (
                <li
                  id={dish.slug[locale]}
                  class="scroll-mt-24 rounded-lg border border-cream-200 bg-cream-50/70 p-4 transition-colors hover:border-leaf-700/25 hover:bg-cream-50"
                >
                  <div class="flex gap-4">
                    {dish.images[0] && (
                      <img
                        src={dish.images[0]}
                        alt={dish.name[locale]}
                        loading="lazy"
                        width="160"
                        height="160"
                        class="h-20 w-20 shrink-0 rounded-md border border-cream-300 object-cover"
                      />
                    )}
                    <div class="min-w-0 flex-1">
                      <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-3">
                        <h3 class="text-base leading-snug font-extrabold sm:text-lg">
                          {dish.name[locale]}
                        </h3>
                        <span class="text-lg font-bold whitespace-nowrap text-leaf-800 tabular-nums">
                          ฿{dish.price_thb}
                        </span>
                      </div>
                      {dish.description?.[locale] && (
                        <p class="mt-1.5 max-w-[56ch] text-sm leading-relaxed text-ink-500">
                          {dish.description[locale]}
                        </p>
                      )}
                      {(dish.dietaryTags.length > 0 ||
                        dish.spicyLevel > 0 ||
                        dish.allergens.length > 0) && (
                        <p class="mt-2.5 flex flex-wrap items-center gap-x-2 gap-y-1.5">
                          {dish.dietaryTags.map((tag) =>
                            tag === 'jay' ? (
                              <JayBadge size="sm" label={t(locale, 'tag.jay')} />
                            ) : (
                              <span class="rounded-full border border-leaf-700/25 bg-leaf-50 px-2 py-0.5 text-[11px] font-semibold tracking-wide text-leaf-800 uppercase">
                                {TAG_ICONS[tag] && `${TAG_ICONS[tag]} `}
                                {t(locale, `tag.${tag}` as UiKey)}
                              </span>
                            ),
                          )}
                          {dish.spicyLevel > 0 && (
                            <span
                              role="img"
                              aria-label={`${t(locale, 'menu.spicy')} ${dish.spicyLevel}/3`}
                              class="text-sm"
                            >
                              {'🌶'.repeat(dish.spicyLevel)}
                            </span>
                          )}
                          {dish.allergens.length > 0 && (
                            <span class="text-xs text-ink-500 italic">
                              {t(locale, 'menu.contains')}:{' '}
                              {dish.allergens.map((a) => allergenName(a.id)).join(', ')}
                            </span>
                          )}
                        </p>
                      )}
                    </div>
                  </div>
                </li>
              ))}
            </ul>
            <p class="mt-2 text-right">
              <a
                href="#top"
                class="inline-flex min-h-11 items-center gap-1 text-sm font-semibold text-leaf-700 transition-colors hover:text-leaf-900"
              >
                ↑ {t(locale, 'menu.backToTop')}
              </a>
            </p>
          </section>
        );
      })
    }
    {
      grabLink && (
        <section class="mt-14 mb-10 rounded-lg border border-leaf-100 bg-leaf-50 px-6 py-8 text-center sm:px-10">
          <p class="text-xl font-black text-leaf-900">{t(locale, 'menu.orderClosing')}</p>
          <p class="mt-4">
            <a
              href={grabLink.url}
              rel="noopener"
              class="inline-flex min-h-12 items-center rounded-lg bg-leaf-700 px-7 font-bold text-cream-50 transition-colors hover:bg-leaf-800"
            >
              {t(locale, 'menu.orderGrab')}
            </a>
          </p>
        </section>
      )
    }
  </div>
</Base>
