---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import LeafDivider from '../../components/LeafDivider.astro';
import Sprig from '../../components/Sprig.astro';
import { localeStaticPaths, type Locale } from '../../lib/i18n';
import { absoluteUrl, localePath, structuralAlternates } from '../../lib/urls';
import { buildBreadcrumb, buildRestaurant } from '../../lib/jsonld';
import { t, type UiKey } from '../../lib/ui';

export function getStaticPaths() {
  return localeStaticPaths();
}

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const [settings] = (await getCollection('settings')).map((e) => e.data);
const [location] = (await getCollection('locations')).map((e) => e.data);
if (!settings || !location) throw new Error('settings/locations content is missing');

const alternates = structuralAlternates('/contact/');
const site = Astro.site!;

const title = {
  en: 'Contact & location — Apple Vegan Cafe Pattaya',
  th: 'ติดต่อและแผนที่ — ร้านอาหารเจ คาเฟ่เจ พัทยา',
  ru: 'Контакты и адрес — Apple Vegan Cafe, Паттайя',
}[locale];
const description = {
  en: 'Address, opening hours, phone and directions to Apple Vegan Cafe & Restaurant in Pattaya (Bang Lamung, Chonburi).',
  th: 'ที่อยู่ เวลาเปิด-ปิด โทรศัพท์ และวิธีเดินทางมาร้านอาหารเจ คาเฟ่เจ พัทยา',
  ru: 'Адрес, часы работы, телефон и как добраться до Apple Vegan Cafe в Паттайе.',
}[locale];

const jsonld = [
  buildRestaurant({
    name: settings.name,
    url: absoluteUrl(site, '/'),
    menuUrl: absoluteUrl(site, localePath(locale, '/menu/')),
    telephone: settings.phone,
    address: location.address.en,
    geo: location.geo,
    images: [],
    sameAs: settings.social.map((s) => s.url),
    hours: location.hours,
    orderUrl: settings.orderingLinks.find((l) => l.provider.toLowerCase().includes('grab'))?.url,
  }),
  buildBreadcrumb([
    { name: t(locale, 'nav.home'), url: absoluteUrl(site, localePath(locale, '/')) },
    { name: t(locale, 'nav.contact'), url: absoluteUrl(site, localePath(locale, '/contact/')) },
  ]),
];

const dayLabel = (day: string) => t(locale, `days.${day}` as UiKey);
const daysLabel = (days: readonly string[]) =>
  days.length === 7
    ? t(locale, 'days.daily')
    : days.length > 2
      ? `${dayLabel(days[0]!)}–${dayLabel(days.at(-1)!)}`
      : days.map(dayLabel).join(', ');
const phoneHref = `tel:${settings.phone.replace(/\s/g, '')}`;
---

<Base {locale} {title} {description} {alternates} {jsonld}>
  <div class="page-shell wrap py-10 sm:py-14">
    <h1 class="font-display text-4xl font-extrabold tracking-tight text-leaf-900 sm:text-5xl">
      {t(locale, 'nav.contact')}
    </h1>
    <LeafDivider class="mt-6 max-w-52 sm:max-w-60" />

    {
      /* Balanced two-column composition: address + phone stacked left,
        full-height hours card right (with a corner sprig). */
    }
    <div class="mt-8 grid items-start gap-5 sm:grid-cols-2">
      <div class="grid gap-5">
        <section class="decor-card rounded-lg border border-cream-300 bg-cream-50 p-6 sm:p-7">
          <h2
            class="flex items-center gap-2 text-xs font-bold tracking-[0.14em] text-terracotta-700 uppercase"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            {t(locale, 'contact.address')}
          </h2>
          <p class="mt-3 text-lg leading-relaxed">{location.address[locale]}</p>
          {
            location.mapsUrl && (
              <a
                href={location.mapsUrl}
                rel="noopener"
                class="mt-5 inline-flex min-h-12 items-center rounded-lg border border-leaf-700/40 px-6 font-semibold text-leaf-800 transition-colors hover:border-leaf-700 hover:bg-leaf-100"
              >
                {t(locale, 'contact.findUs')}
              </a>
            )
          }
        </section>

        <section class="decor-card rounded-lg border border-cream-300 bg-cream-50 p-6 sm:p-7">
          <h2
            class="flex items-center gap-2 text-xs font-bold tracking-[0.14em] text-terracotta-700 uppercase"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
            {t(locale, 'contact.phone')}
          </h2>
          <p class="mt-3 text-sm text-ink-500">{t(locale, 'contact.callUs')}</p>
          <a
            href={phoneHref}
            class="mt-4 inline-flex min-h-13 w-full items-center justify-center rounded-lg bg-leaf-700 px-6 text-lg font-bold text-cream-50 transition-colors hover:bg-leaf-800 sm:w-auto"
          >
            {settings.phone}
          </a>
          {
            settings.whatsapp && (
              <p class="mt-4">
                <a
                  href={settings.whatsapp}
                  rel="noopener"
                  class="font-semibold text-leaf-700 underline decoration-mango-500 decoration-2 underline-offset-4 hover:text-leaf-900"
                >
                  WhatsApp
                </a>
              </p>
            )
          }
        </section>
      </div>

      <section
        class="decor-card relative overflow-hidden rounded-lg border border-cream-300 bg-cream-50 p-6 sm:h-full sm:p-7"
      >
        <Sprig
          class="pointer-events-none absolute -right-5 -bottom-7 h-40 w-auto text-leaf-700 opacity-[0.12]"
        />
        <h2
          class="flex items-center gap-2 text-xs font-bold tracking-[0.14em] text-terracotta-700 uppercase"
        >
          <svg
            viewBox="0 0 24 24"
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 6v6l4 2"></path>
          </svg>
          {t(locale, 'contact.hours')}
        </h2>
        <table class="mt-4 w-full max-w-md text-base">
          <tbody class="divide-y divide-cream-200">
            {
              location.hours.map((h) => (
                <tr>
                  <th scope="row" class="py-2.5 pr-6 text-left font-medium">
                    {daysLabel(h.days)}
                  </th>
                  <td class="py-2.5 font-semibold text-leaf-800 tabular-nums">
                    {h.open}–{h.close}
                  </td>
                </tr>
              ))
            }
            <tr>
              <th scope="row" class="py-2.5 pr-6 text-left font-medium">
                {t(locale, 'hours.delivery')}
              </th>
              <td class="py-2.5 font-semibold text-leaf-800">
                {t(locale, 'hours.deliveryValue')}
              </td>
            </tr>
          </tbody>
        </table>
        <p class="mt-4 max-w-[46ch] text-sm leading-relaxed text-ink-500">
          🌙 {t(locale, 'contact.nightOrders')}
        </p>
      </section>
    </div>
  </div>
</Base>
