---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import LeafDivider from '../../../components/LeafDivider.astro';
import Sprig from '../../../components/Sprig.astro';
import { localeStaticPaths, type Locale } from '../../../lib/i18n';
import { absoluteUrl, localePath, structuralAlternates } from '../../../lib/urls';
import { buildBreadcrumb } from '../../../lib/jsonld';
import { t } from '../../../lib/ui';

export function getStaticPaths() {
  return localeStaticPaths();
}

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const articles = (
  await getCollection('articles', ({ data }) => data.locale === locale && !data.draft)
).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const alternates = structuralAlternates('/blog/');
const site = Astro.site!;

const title = {
  en: 'Blog — Apple Vegan Cafe Pattaya',
  th: 'บทความ — ร้านอาหารเจ คาเฟ่เจ พัทยา',
  ru: 'Блог — Apple Vegan Cafe, Паттайя',
}[locale];
const description = {
  en: 'Stories, vegan food guides and news from our family cafe in Pattaya.',
  th: 'เรื่องราว ไกด์อาหารเจ และข่าวจากร้านครอบครัวของเราในพัทยา',
  ru: 'Истории, гиды по веганской еде и новости нашего семейного кафе в Паттайе.',
}[locale];

const jsonld = [
  buildBreadcrumb([
    { name: t(locale, 'nav.home'), url: absoluteUrl(site, localePath(locale, '/')) },
    { name: t(locale, 'nav.blog'), url: absoluteUrl(site, localePath(locale, '/blog/')) },
  ]),
];

const dateFmt = new Intl.DateTimeFormat(locale, { dateStyle: 'long' });
---

<Base {locale} {title} {description} {alternates} {jsonld}>
  <div class="page-shell wrap relative py-10 sm:py-14">
    <Sprig
      class="pointer-events-none absolute top-10 right-0 hidden h-72 w-auto rotate-12 text-leaf-700 opacity-[0.1] lg:block"
    />
    <div class="mx-auto max-w-[65ch]">
      <h1 class="font-display text-4xl font-extrabold tracking-tight text-leaf-900 sm:text-5xl">
        {t(locale, 'nav.blog')}
      </h1>
      <LeafDivider class="mt-6 max-w-52 sm:max-w-60" />
      <ul class="mt-10 space-y-6">
        {
          articles.map(({ data: article }) => (
            <li>
              <article class="decor-card rounded-lg border border-cream-300 bg-cream-50 px-5 py-5 transition-colors hover:border-leaf-700/35 hover:bg-leaf-50">
                <p class="text-xs font-bold tracking-[0.14em] text-terracotta-700 uppercase">
                  <time datetime={article.publishedAt.toISOString().slice(0, 10)}>
                    {dateFmt.format(article.publishedAt)}
                  </time>
                </p>
                <h2 class="mt-2 font-display text-2xl leading-snug font-bold text-balance">
                  <a
                    href={localePath(locale, `/blog/${article.slug}/`)}
                    class="transition-colors hover:text-leaf-700"
                  >
                    {article.title}
                  </a>
                </h2>
                <p class="mt-2 leading-relaxed text-ink-700">{article.description}</p>
                <p class="mt-3">
                  <a
                    href={localePath(locale, `/blog/${article.slug}/`)}
                    class="font-semibold text-leaf-700 underline decoration-mango-500 decoration-2 underline-offset-4 transition-colors hover:text-leaf-900"
                  >
                    {t(locale, 'blog.readMore')} →
                  </a>
                </p>
              </article>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</Base>
