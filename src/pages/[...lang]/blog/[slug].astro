---
import { getCollection, getEntry, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import LeafDivider from '../../../components/LeafDivider.astro';
import Sprig from '../../../components/Sprig.astro';
import { DEFAULT_LOCALE, type Locale, type PartiallyLocalized } from '../../../lib/i18n';
import { absoluteUrl, localePath } from '../../../lib/urls';
import { buildArticle, buildBreadcrumb } from '../../../lib/jsonld';
import { t } from '../../../lib/ui';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((entry) => ({
    params: {
      lang: entry.data.locale === DEFAULT_LOCALE ? undefined : entry.data.locale,
      slug: entry.data.slug,
    },
    props: { entry },
  }));
}

interface Props {
  entry: Awaited<ReturnType<typeof getCollection<'articles'>>>[number];
}
const { entry } = Astro.props;
const locale = entry.data.locale as Locale;

// All existing translations of this article → hreflang alternates with localized slugs
const translations = await getCollection(
  'articles',
  ({ data }) => data.translationKey === entry.data.translationKey && !data.draft,
);
const alternates: PartiallyLocalized = Object.fromEntries(
  translations.map((tr) => [tr.data.locale, localePath(tr.data.locale, `/blog/${tr.data.slug}/`)]),
);

const author = await getEntry(entry.data.author);
const { Content } = await render(entry);

const site = Astro.site!;
const url = absoluteUrl(site, localePath(locale, `/blog/${entry.data.slug}/`));

const jsonld = [
  buildArticle({
    title: entry.data.title,
    description: entry.data.description,
    url,
    locale,
    authorName: author?.data.name ?? 'Apple Vegan Cafe',
    publishedAt: entry.data.publishedAt,
    updatedAt: entry.data.updatedAt,
  }),
  buildBreadcrumb([
    { name: t(locale, 'nav.home'), url: absoluteUrl(site, localePath(locale, '/')) },
    { name: t(locale, 'nav.blog'), url: absoluteUrl(site, localePath(locale, '/blog/')) },
    { name: entry.data.title, url },
  ]),
];

const dateFmt = new Intl.DateTimeFormat(locale, { dateStyle: 'long' });
---

<Base
  {locale}
  title={entry.data.seo?.title ?? entry.data.title}
  description={entry.data.seo?.description ?? entry.data.description}
  {alternates}
  ogType="article"
  {jsonld}
>
  <article class="page-shell wrap relative py-10 sm:py-14">
    <Sprig
      class="pointer-events-none absolute top-10 right-0 hidden h-72 w-auto rotate-12 text-leaf-700 opacity-[0.1] lg:block"
    />
    <div class="mx-auto max-w-[65ch]">
      <header>
        <p class="text-xs font-bold tracking-[0.14em] text-terracotta-700 uppercase">
          <time datetime={entry.data.publishedAt.toISOString().slice(0, 10)}>
            {dateFmt.format(entry.data.publishedAt)}
          </time>
        </p>
        <h1
          class="mt-3 font-display text-4xl leading-tight font-extrabold tracking-tight text-balance text-leaf-900 sm:text-5xl"
        >
          {entry.data.title}
        </h1>
        <LeafDivider class="mt-7 max-w-60" />
      </header>
      <div class="prose-editorial mt-8">
        <Content />
      </div>
    </div>
  </article>
</Base>
