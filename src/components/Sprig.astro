---
/**
 * Hand-drawn botanical sprig (single-color line art). Purely decorative:
 * always rendered aria-hidden. Color via currentColor, size via class.
 */
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  viewBox="0 0 140 180"
  fill="none"
  stroke="currentColor"
  stroke-width="2.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  class:list={[className]}
>
  <path d="M70 174 C66 138 74 104 70 62 C68 40 72 22 78 8"></path>
  <path d="M69 150 C52 146 40 134 37 117 C55 122 66 134 69 150 Z"></path>
  <path d="M70 118 C54 113 44 100 42 84 C59 90 68 102 70 118 Z"></path>
