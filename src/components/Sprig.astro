  <path d="M70 134 C86 130 97 118 100 102 C83 106 72 118 70 134 Z"></path>
  <path d="M70 102 C85 97 95 85 97 69 C81 75 71 87 70 102 Z"></path>
  <path d="M71 70 C84 64 91 53 92 38 C78 45 72 56 71 70 Z"></path>
  <path d="M78 8 C84 15 86 25 83 35 C76 29 74 18 78 8 Z"></path>
