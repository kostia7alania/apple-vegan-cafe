---
import { LOCALES, LOCALE_LABELS, type Locale, type PartiallyLocalized } from '../lib/i18n';
import { localePath } from '../lib/urls';
import { t } from '../lib/ui';

/**
 * Language toggle: a globe button opening a CSS-only dropdown (<details>) —
 * zero JS, scales to 10+ locales without crowding the header.
 *
 * SEO/UX invariants (keep!):
 * - every locale link is a plain crawlable <a hreflang lang> in the DOM
 *   (details content is parsed regardless of open state);
 * - a page with no translation falls back to that locale's HOME — the
 *   switcher never disappears and never dead-ends;
 * - endonyms only (ไทย, Русский), never flags; order = LOCALES, identical
 *   on every page;
 * - the panel closes itself on navigation; with CSS-only <details> it stays
 *   open until re-tap otherwise — acceptable, selection always navigates.
 */
interface Props {
  locale: Locale;
  alternates: PartiallyLocalized;
}

const { locale, alternates } = Astro.props;
const items = LOCALES.map((l) => ({
  locale: l,
  label: LOCALE_LABELS[l],
  href: l === locale ? null : (alternates[l] ?? localePath(l, '/')),
}));
---

<details class="group relative">
  <summary
    class="flex min-h-9 cursor-pointer list-none items-center gap-1.5 rounded-full border border-cream-300 bg-cream-50 px-3 text-xs font-semibold text-ink-700 transition-colors select-none group-open:border-leaf-600 group-open:bg-leaf-50 hover:border-leaf-600 hover:bg-leaf-50 hover:text-leaf-800 [&::-webkit-details-marker]:hidden"
    aria-label={t(locale, 'lang.switch')}
  >
    <svg
      viewBox="0 0 24 24"
      class="h-4 w-4"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <path
        d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
      ></path>
    </svg>
    {LOCALE_LABELS[locale]}
    <svg
      viewBox="0 0 24 24"
      class="h-3 w-3 transition-transform group-open:rotate-180"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </summary>

  <nav
    aria-label={t(locale, 'lang.switch')}
    class="absolute right-0 z-40 mt-2 min-w-36 rounded-2xl border border-cream-300 bg-cream-50 py-1.5 shadow-lg shadow-ink-900/10"
  >
    <ul>
      {
        items.map((item) =>
          item.href ? (
            <li>
              <a
                href={item.href}
                lang={item.locale}
                hreflang={item.locale}
                class="flex min-h-10 items-center px-4 text-sm font-medium text-ink-700 transition-colors hover:bg-leaf-50 hover:text-leaf-900"
              >
                {item.label}
              </a>
            </li>
          ) : (
            <li>
              <span
                aria-current="true"
                class="flex min-h-10 items-center gap-2 px-4 text-sm font-semibold text-leaf-900"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="h-3.5 w-3.5 text-leaf-700"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M20 6 9 17l-5-5" />
                </svg>
                {item.label}
              </span>
            </li>
          ),
        )
      }
    </ul>
  </nav>
</details>
