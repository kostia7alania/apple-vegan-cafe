---
import { LOCALES, LOCALE_LABELS, type Locale, type PartiallyLocalized } from '../lib/i18n';
import Flag from './Flag.astro';
import { localePath } from '../lib/urls';
import { t } from '../lib/ui';

/**
 * Language toggle: a globe button opening a CSS-only dropdown (<details>) —
 * zero JS, scales to 10+ locales without crowding the header.
 *
 * SEO/UX invariants (keep!):
 * - every locale link is a plain crawlable <a hreflang lang> in the DOM
 *   (details content is parsed regardless of open state);
 * - a page with no translation falls back to that locale's HOME — the
 *   switcher never disappears and never dead-ends;
 * - endonyms always present (ไทย, Русский); flags are a visual anchor ONLY,
 *   next to the endonym, never replacing it; order = LOCALES, identical on
 *   every page;
 * - the panel closes itself on navigation; with CSS-only <details> it stays
 *   open until re-tap otherwise — acceptable, selection always navigates.
 */
interface Props {
  locale: Locale;
  alternates: PartiallyLocalized;
}

const { locale, alternates } = Astro.props;
const items = LOCALES.map((l) => ({
  locale: l,
  label: LOCALE_LABELS[l],
  href: l === locale ? null : (alternates[l] ?? localePath(l, '/')),
}));
---

<details class="group relative">
  <summary
    class="lang-summary flex h-9 cursor-pointer list-none items-center gap-2 rounded-full border border-cream-300 bg-cream-50 px-3 text-xs font-semibold text-ink-700 transition-colors select-none group-open:border-leaf-600 group-open:bg-leaf-50 hover:border-leaf-600 hover:bg-leaf-50 hover:text-leaf-800"
    aria-label={t(locale, 'lang.switch')}
  >
    <Flag {locale} />
    {LOCALE_LABELS[locale]}
    <svg
      viewBox="0 0 24 24"
      class="h-3 w-3 transition-transform duration-150 group-open:rotate-180"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </summary>

  <nav
    aria-label={t(locale, 'lang.switch')}
    class="lang-panel absolute right-0 z-50 mt-2 min-w-40 rounded-2xl border border-cream-300 bg-cream-50 py-1.5 shadow-lg shadow-ink-900/10"
  >
    <ul>
      {
        items.map((item) =>
          item.href ? (
            <li>
              <a
                href={item.href}
                lang={item.locale}
                hreflang={item.locale}
                class="mx-1.5 flex min-h-10 items-center gap-2.5 rounded-xl px-2.5 text-sm font-medium text-ink-700 transition-colors hover:bg-leaf-50 hover:text-leaf-900"
              >
                <Flag locale={item.locale} />
                {item.label}
              </a>
            </li>
          ) : (
            <li>
              <span
                aria-current="true"
                class="mx-1.5 flex min-h-10 items-center gap-2.5 rounded-xl bg-leaf-100 px-2.5 text-sm font-semibold text-leaf-900"
              >
                <Flag locale={item.locale} />
                {item.label}
              </span>
            </li>
          ),
        )
      }
    </ul>
  </nav>
</details>
