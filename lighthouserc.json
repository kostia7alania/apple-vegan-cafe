{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": ["/", "/menu/", "/th/menu/", "/ru/"],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "resource-summary:script:size": ["error", { "maxNumericValue": 10240 }]
      }
    }
  }
}
