{
  "name": "apple-vegan-cafe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Official website of Apple Vegan Cafe & Restaurant, Pattaya — static, multilingual (EN/TH/RU), zero-JS Astro site",
  "license": "MIT",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm run generate:redirects && astro build --force",
    "preview": "astro preview",
    "check": "astro check && tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "validate:content": "tsx scripts/validate-content.ts",
    "generate:redirects": "tsx scripts/generate-redirects.ts",
    "import:menu": "tsx scripts/import-menu.ts",
    "deploy": "wrangler deploy --config infrastructure/wrangler.jsonc"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.9",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.0",
    "linkinator": "^7.6.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0",
    "yaml": "^2.9.0"
  }
}
