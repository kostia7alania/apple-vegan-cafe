# Public build-time configuration only. There are NO server secrets in this project.
# GitHub OAuth client id/secret for the CMS live ONLY in the Cloudflare dashboard
# (sveltia-cms-auth Worker secrets) — never here, never in the repo.
PUBLIC_SITE_URL=https://apple-vegan-cafe.com

# Optional analytics. Public IDs only; leave empty to ship zero analytics JS.
# For this cafe, Cloudflare Web Analytics is the recommended lightweight default.
PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=
PUBLIC_GA_MEASUREMENT_ID=
