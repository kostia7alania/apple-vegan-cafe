# Security headers for Cloudflare Workers Static Assets.
# Applies to statically served assets only (this site is 100% static).
# CSP starts from default-src 'none' and allowlists what the site actually uses.
# 'unsafe-inline' for styles is required by Astro's inlined <style> blocks.

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=()
  Content-Security-Policy: default-src 'none'; img-src 'self' data: https://www.google-analytics.com; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://www.googletagmanager.com; connect-src 'self' https://cloudflareinsights.com https://www.google-analytics.com https://region1.google-analytics.com; base-uri 'none'; form-action 'self'; frame-ancestors 'none'; manifest-src 'self'; upgrade-insecure-requests

# The CMS admin page loads Sveltia from a pinned CDN URL and talks to the
# GitHub API + the sveltia-cms-auth Worker. Scoped override, admin only.
# `!` DETACHES the CSP inherited from /* — otherwise the browser enforces the
# intersection of both policies and blocks the CDN script (blank admin page).
/admin/*
  X-Robots-Tag: noindex
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'none'; script-src 'self' https://unpkg.com https://static.cloudflareinsights.com; worker-src 'self' blob:; connect-src 'self' data: https://api.github.com https://raw.githubusercontent.com https://github.com https://auth.apple-vegan-cafe.com https://unpkg.com https://www.githubstatus.com https://cloudflareinsights.com; img-src 'self' blob: data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; media-src 'self' blob:; base-uri 'none'; form-action 'self'; frame-ancestors 'none'
